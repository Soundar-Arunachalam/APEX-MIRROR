# =============================================================================
# PSP Switch — Environment Variable Reference
# =============================================================================
# Copy this file to .env and populate secrets before deploying.
# All variables have safe defaults for local/dev use.
# =============================================================================

# ─── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ─── Kafka Topic Names (override if your broker uses different names) ─────────
KAFKA_TOPIC_PAYMENT_REQUESTS=psp.payment.initiate.request
KAFKA_TOPIC_NPCI_OUTBOUND=npci.outbound.request
KAFKA_TOPIC_NPCI_RESPONSE=npci.inbound.response
KAFKA_TOPIC_SWITCH_COMPLETED=psp.switch.completed.events

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Per-service DB URLs (used when NOT running via docker-compose)
POSTGRES_URL_INGRESS=jdbc:postgresql://localhost:5432/tpap_ingress
POSTGRES_URL_ORCHESTRATOR=jdbc:postgresql://localhost:5432/orchestrator
POSTGRES_URL_EGRESS=jdbc:postgresql://localhost:5432/egress_db
POSTGRES_URL_LEDGER=jdbc:postgresql://localhost:5432/ledger_db

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_TIMEOUT_MS=2000

# ─── NPCI Configuration ───────────────────────────────────────────────────────
# Base URL for the NPCI UPI endpoint (mock: 9090, production: use real NPCI URL)
NPCI_BASE_URL=http://localhost:9090

# Organisation ID assigned to your PSP by NPCI
NPCI_ORG_ID=DEMOPSP

# HTTP client timeouts for NPCI calls (milliseconds)
NPCI_CONNECT_TIMEOUT_MS=5000
NPCI_READ_TIMEOUT_MS=30000
NPCI_MAX_CONNECTIONS=50

# Saga timeout — how long to wait for NPCI response before marking UNKNOWN
NPCI_TIMEOUT_SECONDS=30

# ─── mTLS (set to true for NPCI production) ───────────────────────────────────
NPCI_MTLS_ENABLED=false
NPCI_KEYSTORE_PATH=
NPCI_KEYSTORE_PASSWORD=
NPCI_TRUSTSTORE_PATH=
NPCI_TRUSTSTORE_PASSWORD=

# ─── NPCI Response Consumer ───────────────────────────────────────────────────
# Enable XML signature verification for NPCI callbacks
NPCI_VERIFY_SIGNATURE=false
NPCI_CALLBACK_SECRET=

# ─── PSP Identity ─────────────────────────────────────────────────────────────
PSP_ID=DEMOPSP

# ─── AES-256 PII Encryption ───────────────────────────────────────────────────
# CHANGE THIS KEY IN PRODUCTION — must be exactly 32 ASCII characters
CRYPTO_ENABLED=true
CRYPTO_SECRET_KEY=PSPSwitch2024DemoKey1234567890AB

# Ledger service crypto (can be same as CRYPTO_SECRET_KEY)
LEDGER_CRYPTO_ENABLED=true
LEDGER_CRYPTO_KEY=PSPSwitch2024DemoKey1234567890AB

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── Server Ports (per service, optional override) ────────────────────────────
# PORT_TPAP_INGRESS=8080
# PORT_ORCHESTRATOR=8081
# PORT_NPCI_ADAPTER=8082
# PORT_TPAP_EGRESS=8083
# PORT_NPCI_RESPONSE_CONSUMER=8084
# PORT_LEDGER=8085
